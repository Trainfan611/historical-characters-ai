# Database
DATABASE_URL="postgresql://user:password@localhost:5432/historical_characters"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Telegram
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHANNEL_ID="@your-channel-or-channel-id"
TELEGRAM_ADMIN_ID="123456789"

# Paid subscriptions
# Telegram IDs with active paid plan "Pro 100" (comma-separated)
PAID_SUBSCRIBERS_TELEGRAM_IDS="123456789,987654321"
# Contact for custom plans (>100 generations/day)
SUBSCRIPTION_SALES_CONTACT="@manager_username"

# AI APIs
REPLICATE_API_KEY="your-replicate-api-key"  # Для генерации изображений (Flux)
# или используйте OpenRouter (требует дополнительной настройки)
OPENROUTER_API_KEY="your-openrouter-api-key"
PERPLEXITY_API_KEY="your-perplexity-api-key"
OPENAI_API_KEY="your-openai-api-key"

# Telegram Login Widget (опционально)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="your_bot_username"

# Storage (optional for production)
# S3_BUCKET_NAME=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
